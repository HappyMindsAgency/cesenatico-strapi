{
  "kind": "collectionType",
  "collectionName": "eventi",
  "info": {
    "singularName": "evento",
    "pluralName": "eventi",
    "displayName": "Evento"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "titolo": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "slug": {
      "type": "uid",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "targetField": "titolo"
    },
    "cover": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "prezzo": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "gratuito"
            },
            false
          ]
        }
      }
    },
    "inEvidenza": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "custom.in-evidenza",
      "repeatable": false
    },
    "descrizione": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "dataInizio": {
      "type": "date",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "dataFine": {
      "type": "date",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "gratuito": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "default": true
    },
    "organizzatori": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "linkEtichetta": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "linkUrl": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "localita": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "categoria_evento": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::categoria-evento.categoria-evento"
    },
    "operatore": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::operatore.operatore",
      "inversedBy": "evento"
    },
    "stagionalitas": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::stagionalita.stagionalita"
    },
    "prenotazione": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "default": false
    },
    "accessibile": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "default": true
    },
    "seo": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "seo-component.seo",
      "repeatable": false
    },
    "ricorrenza": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "custom.ricorrenza",
      "repeatable": false
    },
    "eventoGenitore": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::evento.evento",
      "inversedBy": "eventiFigli"
    },
    "eventiFigli": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::evento.evento",
      "mappedBy": "eventoGenitore"
    },
    "majorEvent": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "default": false
    },
    "struttura": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::struttura.struttura",
      "inversedBy": "eventi"
    }
  }
}
